---
const anio = new Date().getFullYear();
---

<footer id="contacto" class="footer">
	<div class="footer-main">
		<div class="container">
			<div class="footer-grid">
				<div class="footer-brand">
					<img
						src="/lorenails-tarjetap.svg"
						alt="Lorenails"
						class="footer-logo"
					/>
					<p class="footer-descripcion">
						Tu salón de uñas de confianza. Diseño profesional y
						servicios exclusivos para mimarte.
					</p>
				</div>

				<div class="footer-links">
					<h4 class="footer-titulo">Enlaces Rápidos</h4>
					<ul class="footer-menu">
						<li><a href="#inicio">Inicio</a></li>
						<li><a href="#servicios">Servicios</a></li>
						<li><a href="#galeria">Galería</a></li>
						<li><a href="#contacto">Contacto</a></li>
					</ul>
				</div>

				<div class="footer-contacto">
					<h4 class="footer-titulo">Contacto</h4>
					<ul class="footer-info">
						<li>
							<span class="footer-icono">📍</span>
							1 Norte N.º 1990, Talca, Chile
						</li>
						<li>
							<span class="footer-icono">📱</span>
							+56 9 1234 5678
						</li>
						<li>
							<span class="footer-icono">✉️</span>
							contacto@lorenails.cl
						</li>
						<li>
							<span class="footer-icono">🕐</span>
							Lunes - Viernes: 10:00 - 18:00
						</li>
					</ul>
				</div>

				<div class="footer-social">
					<h4 class="footer-titulo">Síguenos</h4>
					<div class="social-links">
						<a href="https://www.instagram.com/lorenailscl" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
								<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
								<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="footer-bottom">
		<div class="container">
			<p class="footer-copyright">
				© {anio} Lorenails.cl Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background: var(--color-text);
		color: white;
	}

	.footer-main {
		padding: var(--spacing-3xl) 0 var(--spacing-xl);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: var(--spacing-2xl);
	}

	.footer-logo {
		height: 80px;
		margin-bottom: var(--spacing-md);
	}

	.footer-descripcion {
		color: rgba(255, 255, 255, 0.7);
		line-height: 1.6;
		max-width: 300px;
	}

	.footer-titulo {
		font-size: 1.1rem;
		font-weight: 600;
		margin-bottom: var(--spacing-lg);
		color: var(--color-primary-light);
	}

	.footer-menu {
		list-style: none;
	}

	.footer-menu li {
		margin-bottom: var(--spacing-sm);
	}

	.footer-menu a {
		color: rgba(255, 255, 255, 0.7);
		transition: var(--transition);
	}

	.footer-menu a:hover {
		color: var(--color-primary-light);
	}

	.footer-info {
		list-style: none;
	}

	.footer-info li {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
		margin-bottom: var(--spacing-sm);
		color: rgba(255, 255, 255, 0.7);
	}

	.footer-icono {
		font-size: 1.1rem;
	}

	.social-links {
		display: flex;
		gap: var(--spacing-md);
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		background: rgba(255, 255, 255, 0.1);
		border-radius: 50%;
		font-size: 1.25rem;
		transition: var(--transition);
	}

	.social-link:hover {
		background: var(--color-primary);
		transform: translateY(-3px);
	}

	.footer-bottom {
		background: rgba(0, 0, 0, 0.2);
		padding: var(--spacing-md) 0;
	}

	.footer-copyright {
		text-align: center;
		color: rgba(255, 255, 255, 0.5);
		font-size: 0.875rem;
	}

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.footer-descripcion {
			max-width: none;
		}

		.footer-info li {
			justify-content: center;
		}

		.social-links {
			justify-content: center;
		}
	}
</style>
