---
const galerieItems = [
	{ id: 1, titulo: "Diseño Floral", categoria: "Nail Art" },
	{ id: 2, titulo: "Uñas Francesas", categoria: "Clasico" },
	{ id: 3, titulo: "Diseño Geometrico", categoria: "Nail Art" },
	{ id: 4, titulo: "Uñas con Gel", categoria: "Tratamiento" },
];
---

<section id="galeria" class="galeria section">
	<div class="container">
		<h2 class="section-title">Galeria de Diseños</h2>
		<p class="section-subtitle">
			Inspirate con nuestros diseños mas recientes. Cada uñas es unica,
			creada especialmente para ti.
		</p>

		<div class="galeria-grid">
			{
				galerieItems.map((item) => (
					<div class="galeria-item">
						<div class="galeria-imagen">
							<img
								src="/lorenails-tarjetap.svg"
								alt={item.titulo}
							/>
						</div>
						<div class="galeria-info">
							<span class="galeria-categoria">
								{item.categoria}
							</span>
							<h3 class="galeria-titulo">{item.titulo}</h3>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.galeria {
		background: linear-gradient(135deg, #fafafa 0%, #fdf2f8 100%);
		overflow: hidden;
	}

	.galeria-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-lg);
	}

	.galeria-item {
		background: var(--color-surface);
		border-radius: var(--border-radius-lg);
		overflow: hidden;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
		transition: var(--transition);
		cursor: pointer;
	}

	.galeria-item:hover {
		transform: translateY(-8px);
		box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
	}

	.galeria-imagen {
		aspect-ratio: 1;
		background: #fff5f7;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-lg);
	}

	.galeria-imagen img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.galeria-info {
		padding: var(--spacing-md);
	}

	.galeria-categoria {
		display: inline-block;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-primary);
		background: rgba(217, 68, 112, 0.1);
		padding: 4px 10px;
		border-radius: 20px;
		margin-bottom: var(--spacing-xs);
	}

	.galeria-titulo {
		font-size: 1rem;
		font-weight: 600;
		color: var(--color-text);
	}

	@media (max-width: 1024px) {
		.galeria-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 480px) {
		.galeria-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
